# Lokal (Docker Compose di repo ini — port 5433 agar tidak bentrok dengan Postgres di 5432):
# DATABASE_URL="postgresql://gmrfx:gmrfx_local@127.0.0.1:5433/gmrfx?schema=public"
# DATABASE_URL_UNPOOLED="postgresql://gmrfx:gmrfx_local@127.0.0.1:5433/gmrfx?schema=public"
# DB kedua (Sahabat/Dulur Cirebon) — service `postgres-cirebon`, port host 5434:
# DATABASE_URL="postgresql://dulur_cirebon:dulur_cirebon_local@127.0.0.1:5434/dulur_cirebon?schema=public"
# DATABASE_URL_UNPOOLED="postgresql://dulur_cirebon:dulur_cirebon_local@127.0.0.1:5434/dulur_cirebon?schema=public"
# Atau Postgres terpasang manual — sesuaikan user/password/db.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/NAMA_DB?schema=public"
# Wajib untuk `prisma migrate deploy` (sama dengan DATABASE_URL jika tidak pakai pooler):
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@localhost:5432/NAMA_DB?schema=public"
# Neon: DATABASE_URL = pooled (?sslmode=require), DATABASE_URL_UNPOOLED = direct (bukan -pooler).
# Neon (pooler): tambahkan &pgbouncer=true pada DATABASE_URL jika Prisma gagal menulis —
# di kode, host *.neon.tech otomatis diberi pgbouncer=true jika belum ada.
# Tetapkan nilai tetap (jangan kosong, jangan ganti tiap restart). Jika berubah/kosong, JWT tidak valid → semua user terlihat logout.
AUTH_SECRET="generate-a-long-random-string"
# Harus persis URL yang dipakai browser (skema + host). Lokal: http://localhost:3000 — Produksi: https://domain-anda.com (tanpa slash akhir)
# Pakai `npm run dev:https` → set AUTH_URL=https://localhost:3000 (bukan http). Jangan campur localhost vs 127.0.0.1 (cookie terpisah).
AUTH_URL="http://localhost:3000"
# Opsional: samakan dengan AUTH_URL. Di `next.config.mjs`, NEXTAUTH_URL diisi dari AUTH_URL jika baris ini kosong (untuk klien next-auth).
# NEXTAUTH_URL="http://localhost:3000"
# Google OAuth: Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID (Web).
# Authorized redirect URIs (tambahkan keduanya):
#   http://localhost:3000/api/auth/callback/google
#   https://DOMAIN_PRODUCTION/api/auth/callback/google
# Lalu salin Client ID & Client secret ke env di bawah (dan di Vercel → Environment Variables).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Avatar upload di Vercel: Storage → Blob → connect ke proyek; pastikan token ada untuk Production (bukan hanya Preview).
# Tanpa ini, upload hanya jalan di lokal (public/uploads/avatars).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
# `next dev`: unggahan otomatis ke public/uploads (abaikan token Blob di atas).
# Paksa Blob saat dev: UPLOAD_STORAGE=blob
# Paksa disk saat next start lokal: UPLOAD_STORAGE=local
DEV_OTP_CODE="123456"
# ── OTP via WhatsApp (Fonnte) ──────────────────────────────────────────────
# Daftar di https://fonnte.com → sambungkan nomor WhatsApp → salin API token.
# Tanpa ini OTP hanya dicetak di log server (development).
FONNTE_TOKEN=""
# Opsional: perkuat hash token EA MT5 (produksi disarankan acak panjang)
# MT5_TOKEN_PEPPER="random-long-secret"
# Setelah migrate: isi referensi wilayah Indonesia (provinsi/kab/kec) untuk form daftar & lengkapi profil:
# npm run db:seed-wilayah
# Opsional: hentikan pencatatan trafik first-party (beacon ke /api/analytics/pageview)
# SITE_TRAFFIC_DISABLED=1

# ── Deposit USDT (BSC/BEP-20) ─────────────────────────────────────────────────
# Alamat wallet admin tempat member mengirim USDT (BSC BEP-20).
# Isi dengan alamat BSC wallet admin yang Anda kendalikan.
ADMIN_USDT_BSC_ADDRESS=""
# API key BSCScan (gratis di https://bscscan.com/apis — daftar akun lalu buat API key).
# Tanpa API key verifikasi tetap jalan tapi rate-limit lebih ketat (1 req/5 det).
BSCSCAN_API_KEY=""
