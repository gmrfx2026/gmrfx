generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrasi (advisory lock) tidak boleh lewat pooler Neon — pakai koneksi direct.
  // Di Vercel + integrasi Neon: salin nilai env `DATABASE_URL_UNPOOLED`.
  // Lokal tanpa pooler: isi sama dengan DATABASE_URL.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  USER
  ADMIN
}

enum MemberStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum ArticleStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum HomeNewsScope {
  DOMESTIC
  INTERNATIONAL
}

enum HomeNewsStatus {
  DRAFT
  PUBLISHED
}

enum OtpPurpose {
  PHONE_UPDATE
  PASSWORD_CHANGE
  PHONE_VERIFY
  PASSWORD_RESET
}

enum CommentTarget {
  ARTICLE
  STATUS
}

/// Izin mengikuti: langsung aktif vs perlu disetujui dulu (mirip akun privat).
enum FollowApprovalMode {
  AUTO
  APPROVAL_REQUIRED
}

enum MemberFollowStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  FOLLOW_REQUEST
  FOLLOW_ACCEPTED
  NEW_STATUS
  NEW_ARTICLE
  CHAT_DM_REQUEST
  /// Buka/tutup posisi pada akun komunitas yang di-"Ikuti" (bukan Copy trade).
  COMMUNITY_MT_TRADE_ALERT
  /// Langganan Copy trade berbayar (30 hari) telah berakhir.
  COMMUNITY_COPY_SUB_EXPIRED
  /// Langganan alert Ikuti berbayar (30 hari) telah berakhir.
  COMMUNITY_WATCH_SUB_EXPIRED
}

enum ChatDmRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

/// Dana marketplace ditahan hingga masa komplain selesai / admin putuskan.
enum MarketplaceEscrowStatus {
  PENDING
  DISPUTED
  RELEASED
  REFUNDED
}

enum MarketplaceEscrowProductType {
  INDICATOR
  EA
}

enum UsdtDepositStatus {
  PENDING
  VERIFIED
  FAILED
}

enum JobOfferStatus {
  /// Dana sudah dikunci; menunggu pelamar.
  OPEN
  /// Pemenang dipilih; sedang dikerjakan.
  ASSIGNED
  /// Pemenang sudah kirim hasil; menunggu konfirmasi pemberi kerja (auto-release 3 hari).
  DELIVERED
  /// Selesai — dana dikirim ke pemenang.
  COMPLETED
  /// Dibatalkan (expired atau manual) — dana dikembalikan ke pemberi kerja.
  CANCELLED
  /// Ada komplain; admin memutuskan.
  DISPUTED
}

enum JobBidStatus {
  PENDING
  SELECTED
  REJECTED
}

enum JobCategory {
  EA
  INDICATOR
  OTHER
}

model User {
  id              String       @id @default(cuid())
  name            String?
  email           String       @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  role            Role         @default(USER)
  memberStatus    MemberStatus @default(ACTIVE)
  profileComplete Boolean      @default(false)

  phoneWhatsApp String?
  addressLine   String?
  kecamatan     String?
  kabupaten     String?
  provinsi      String?
  kodePos       String?
  negara        String  @default("Indonesia")

  walletAddress String? @unique
  walletBalance Decimal @default(0)

  profileStatus String?
  memberSlug    String? @unique

  /// Pengikut baru langsung aktif, atau menunggu persetujuan Anda.
  followApprovalMode FollowApprovalMode @default(AUTO)

  /// Tautan profil publik (opsional, ditampilkan sebagai ikon di halaman member).
  socialTiktokUrl     String?
  socialInstagramUrl  String?
  socialFacebookUrl   String?
  socialTelegramUrl   String?
  socialYoutubeUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Diperbarui dari klien (member) saat browsing situs; dipakai admin untuk perkiraan "sedang online".
  memberLastSeenAt DateTime?

  accounts               Account[]
  sessions               Session[]
  articles               Article[]          @relation("ArticleAuthor")
  articleRatings         ArticleRating[]
  indicatorRatings       IndicatorRating[]
  eaRatings              EaRating[]
  comments               Comment[]
  otpChallenges          OtpChallenge[]
  sentTransfers          WalletTransfer[]   @relation("TransferFrom")
  receivedTransfers      WalletTransfer[]   @relation("TransferTo")
  shopTransactionsBuyer  ShopTransaction[]  @relation("BuyerTx")
  shopTransactionsSeller ShopTransaction[]  @relation("SellerTx")
  chatMessages           ChatMessage[]
  publicChatMessages    PublicChatMessage[]
  conversationsA         ChatConversation[] @relation("ConvUserA")
  conversationsB         ChatConversation[] @relation("ConvUserB")
  mailSent               InternalMail[]     @relation("MailFrom")
  mailReceived           InternalMail[]     @relation("MailTo")

  statuses StatusEntry[]

  memberRatingsReceived MemberRating[] @relation("MemberRatingsReceived")
  memberRatingsGiven MemberRating[] @relation("MemberRatingsGiven")
  statusLikes         StatusLike[]

  /** Akun ini mengikuti siapa (following). */
  memberFollowsOutgoing MemberFollow[] @relation("MemberFollowsOutgoing")
  /** Siapa yang mengikuti akun ini (followers). */
  memberFollowsIncoming MemberFollow[] @relation("MemberFollowsIncoming")

  notifications Notification[]

  dmRequestsSent     ChatDmRequest[] @relation("DmRequestFrom")
  dmRequestsReceived ChatDmRequest[] @relation("DmRequestTo")

  mtLinkTokens       MtLinkToken[]
  mtDeals            MtDeal[]
  mtAccountSnapshots MtAccountSnapshot[]

  mtCommunityPublishedAccounts MtCommunityPublishedAccount[]
  copyFollowsAsFollower      MtCopyFollow[] @relation("CopyFollowFollower")
  copyFollowsAsPublisher     MtCopyFollow[] @relation("CopyFollowPublisher")
  communityMtWatchesAsFollower MtCommunityActivityWatch[] @relation("CommunityMtWatchFollower")
  communityMtWatchesAsPublisher MtCommunityActivityWatch[] @relation("CommunityMtWatchPublisher")
  mtTradingActivities        MtTradingActivity[]

  /** Berita beranda (DN / internasional); kosong = tampil sebagai redaksi default GMR Fx. */
  authoredHomeNewsItems HomeNewsItem[] @relation("HomeNewsAuthor")

  sharedIndicatorsSold SharedIndicator[]     @relation("SharedIndicatorSeller")
  indicatorPurchases   IndicatorPurchase[]   @relation("IndicatorPurchaseBuyer")
  sharedEasSold        SharedExpertAdvisor[] @relation("SharedExpertAdvisorSeller")
  eaPurchases          ExpertAdvisorPurchase[] @relation("ExpertAdvisorPurchaseBuyer")
  marketplaceEscrowAsBuyer  MarketplaceEscrowHold[] @relation("MarketplaceEscrowBuyer")
  marketplaceEscrowAsSeller MarketplaceEscrowHold[] @relation("MarketplaceEscrowSeller")
  usdtDeposits              UsdtDepositRequest[]

  jobOffersPosted    JobOffer[]       @relation("JobRequester")
  jobOffersWon       JobOffer[]       @relation("JobWinner")
  jobBids            JobBid[]         @relation("JobBidder")
  jobComments        JobComment[]     @relation("JobCommenter")
  jobDeliverables    JobDeliverable[] @relation("JobDeliverer")

  @@index([memberLastSeenAt])
}

/// Token untuk EA MT — verifikasi pakai hash; plaintext disimpan terenkripsi agar pemilik bisa salin lagi.
model MtLinkToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  tokenHint   String
  /// AES-256-GCM (base64url), nullable untuk token lama sebelum migrasi.
  tokenCipher String?
  label       String?
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Deal historis dari MT5 (HistoryDeals) per akun login.
model MtDeal {
  id         String   @id @default(cuid())
  userId     String
  mtLogin    String
  ticket     String
  dealTime   DateTime
  symbol     String
  dealType   Int
  entryType  Int
  volume     Decimal  @db.Decimal(18, 8)
  price      Decimal  @db.Decimal(18, 8)
  commission Decimal  @default(0) @db.Decimal(18, 8)
  swap       Decimal  @default(0) @db.Decimal(18, 8)
  profit     Decimal  @default(0) @db.Decimal(18, 8)
  magic      Int      @default(0)
  comment    String   @default("")
  /// MT5 DEAL_REASON (4=SL, 5=TP, 6=SO, …); dari EA ingest.
  dealReason Int?
  /// ID posisi MT5 (DEAL_POSITION_ID); untuk menjodohkan IN/OUT & hitung durasi nanti.
  positionId         String?
  /// Waktu buka posisi (Unix deal IN pertama), diisi EA untuk kaki penutupan.
  positionOpenTime DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mtLogin, ticket])
  @@index([userId, mtLogin, dealTime])
  @@index([userId, mtLogin, positionId])
}

/// Snapshot saldo/equity dari EA (opsional per sinkronisasi).
model MtAccountSnapshot {
  id         String   @id @default(cuid())
  userId     String
  mtLogin    String
  balance    Decimal  @db.Decimal(18, 8)
  equity     Decimal  @db.Decimal(18, 8)
  margin     Decimal  @default(0) @db.Decimal(18, 8)
  /// Kode mata uang akun (deposit), dari EA: ACCOUNT_CURRENCY / AccountCurrency().
  currency   String?  @db.VarChar(12)
  /// Nama perusahaan/broker (ACCOUNT_COMPANY / AccountCompany).
  brokerName   String?  @db.VarChar(128)
  /// Nama server trading (ACCOUNT_SERVER / AccountServer).
  brokerServer String?  @db.VarChar(128)
  /// Nama akun di terminal (ACCOUNT_NAME / AccountName), dari broker.
  tradeAccountName String? @db.VarChar(128)
  /// mt4 | mt5 dari EA.
  sourcePlatform   String? @db.VarChar(8)
  recordedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mtLogin, recordedAt])
}

/// Snapshot terakhir posisi terbuka & order tertunda dari EA (diperbarui tiap ingest).
model MtTradingActivity {
  id            String   @id @default(cuid())
  userId        String
  mtLogin       String
  positions     Json
  pendingOrders Json
  recordedAt    DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mtLogin])
  @@index([userId])
}

/// Publikasi akun MT ke komunitas (copy trade): izin & harga IDR.
model MtCommunityPublishedAccount {
  id           String   @id @default(cuid())
  userId       String
  mtLogin      String
  allowCopy    Boolean  @default(false)
  /// Tombol & langganan "Ikuti" (alert buka/tutup posisi), terpisah dari Copy.
  allowWatch   Boolean  @default(false)
  /// true = member lain boleh copy gratis; false = wajib bayar copyPriceIdr.
  copyFree     Boolean  @default(true)
  copyPriceIdr Decimal  @default(0) @db.Decimal(18, 2)
  /// Alert "Ikuti" (buka/tutup posisi): terpisah dari harga Copy.
  watchAlertFree     Boolean  @default(true)
  watchAlertPriceIdr Decimal  @default(0) @db.Decimal(18, 2)
  /// "mt5" | "mt4" — dari payload ingest / EA.
  platform     String   @default("mt5") @db.VarChar(8)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mtLogin])
  @@index([allowCopy])
  @@index([allowWatch])
}

/// Member yang memilih "Copy" pada akun komunitas (gratis atau berbayar via wallet).
model MtCopyFollow {
  id              String   @id @default(cuid())
  followerUserId  String
  publisherUserId String
  mtLogin         String
  paidAmountIdr   Decimal  @default(0) @db.Decimal(18, 2)
  /// Semua copy berlaku 30 hari (gratis maupun berbayar); null hanya data lama sebelum kebijakan ini.
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  /// Token unik per langganan — dipakai di EA CopyTrader sebagai Bearer.
  /// Hash SHA-256 dari plain token (dengan pepper). Null untuk data lama.
  copyTokenHash     String?   @unique
  copyTokenHint     String?
  copyTokenIssuedAt DateTime?

  followerUser  User @relation("CopyFollowFollower", fields: [followerUserId], references: [id], onDelete: Cascade)
  publisherUser User @relation("CopyFollowPublisher", fields: [publisherUserId], references: [id], onDelete: Cascade)

  @@unique([followerUserId, publisherUserId, mtLogin])
  @@index([followerUserId])
  @@index([publisherUserId, mtLogin])
  @@index([expiresAt])
  @@index([copyTokenHash])
}

/// Member mengikuti aktivitas posisi (buka/tutup) akun komunitas — terpisah dari Copy trade.
model MtCommunityActivityWatch {
  id              String   @id @default(cuid())
  followerUserId  String
  publisherUserId String
  mtLogin         String
  paidAmountIdr   Decimal  @default(0) @db.Decimal(18, 2)
  /// null = gratis; diisi untuk alert berbayar (30 hari).
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  follower  User @relation("CommunityMtWatchFollower", fields: [followerUserId], references: [id], onDelete: Cascade)
  publisher User @relation("CommunityMtWatchPublisher", fields: [publisherUserId], references: [id], onDelete: Cascade)

  @@unique([followerUserId, publisherUserId, mtLogin])
  @@index([followerUserId])
  @@index([publisherUserId, mtLogin])
  @@index([expiresAt])
}

/// Referensi wilayah Indonesia (kode BPS) — diisi dengan `npm run db:seed-wilayah`.
model IndonesiaProvince {
  id        String             @id
  name      String
  regencies IndonesiaRegency[]
}

model IndonesiaRegency {
  id         String               @id
  provinceId String
  name       String
  province   IndonesiaProvince    @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  districts  IndonesiaDistrict[]
  @@index([provinceId])
}

model IndonesiaDistrict {
  id        String           @id
  regencyId String
  name      String
  regency   IndonesiaRegency @relation(fields: [regencyId], references: [id], onDelete: Cascade)
  @@index([regencyId])
}

/// Permintaan buka chat privat (seperti DM request Instagram) jika belum saling follow.
model ChatDmRequest {
  id            String              @id @default(cuid())
  requesterId   String
  targetId      String
  status        ChatDmRequestStatus @default(PENDING)
  introMessage  String?
  createdAt     DateTime            @default(now())
  respondedAt   DateTime?

  requester User @relation("DmRequestFrom", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("DmRequestTo", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId, status])
}

/// Relasi follow antar member (Instagram-style): follower → following.
model MemberFollow {
  id          String             @id @default(cuid())
  followerId  String
  followingId String
  status      MemberFollowStatus @default(ACCEPTED)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  follower  User @relation("MemberFollowsOutgoing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("MemberFollowsIncoming", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
  @@index([followingId, status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  actorId   String?
  type      NotificationType
  title     String
  body      String?
  linkUrl   String?
  readAt    DateTime?
  statusId  String?
  articleId String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model StatusEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  comments Comment[]    @relation("StatusComments")
  likes    StatusLike[]
}

model StatusLike {
  id        String      @id @default(cuid())
  statusId  String
  status    StatusEntry @relation(fields: [statusId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([statusId, userId])
  @@index([statusId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpChallenge {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  purpose   OtpPurpose
  phone     String
  expiresAt DateTime
  consumed  Boolean    @default(false)
  createdAt DateTime   @default(now())
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  contentHtml String
  status      ArticleStatus @default(PENDING)
  authorId    String
  author      User          @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  ratings  ArticleRating[]
  comments Comment[]
}

model ArticleRating {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stars     Int
  createdAt DateTime @default(now())

  @@unique([articleId, userId])
}

model Comment {
  id            String        @id @default(cuid())
  targetType    CommentTarget
  articleId     String?
  article       Article?      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  statusId      String?
  status        StatusEntry?  @relation("StatusComments", fields: [statusId], references: [id], onDelete: Cascade)
  statusOwnerId String?
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String
  hidden        Boolean       @default(false)
  createdAt     DateTime      @default(now())
}

/// Kunjungan ke halaman /go (pintu keluar ke mitra afiliasi).
model AffiliateGoClick {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  /// ID dari cookie browser (perkiraan pengunjung unik, bukan identitas pasti).
  visitorId  String?
  referer    String?
  userAgent  String?
}

/// Berita beranda (dalam negeri / internasional), impor RSS + opsi parafrase.
model HomeNewsItem {
  id          String         @id @default(cuid())
  scope       HomeNewsScope
  title       String
  slug        String         @unique
  excerpt     String?
  contentHtml String         @default("")
  imageUrl    String?
  sourceUrl   String?
  sourceName  String?
  status      HomeNewsStatus @default(PUBLISHED)
  publishedAt DateTime?
  /// Null = penulis tampil sebagai akun default redaksi (GMR Fx). Isi jika member menulis berita.
  authorId    String?
  author      User?          @relation("HomeNewsAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([scope, status, publishedAt(sort: Desc)])
  @@index([scope, sourceUrl])
  @@index([authorId])
}

model MemberRating {
  id        String   @id @default(cuid())
  memberId  String
  raterId   String
  stars     Int
  createdAt DateTime @default(now())

  member User @relation("MemberRatingsReceived", fields: [memberId], references: [id], onDelete: Cascade)
  rater  User @relation("MemberRatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)

  @@unique([memberId, raterId])
}

model GalleryCategory {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  images      GalleryImage[]
  createdAt   DateTime       @default(now())
}

model GalleryImage {
  id         String          @id @default(cuid())
  categoryId String
  category   GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  imageUrl   String
  caption    String?
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
}

model WalletTransfer {
  id            String   @id @default(cuid())
  transactionId String   @unique
  fromUserId    String
  toUserId      String
  amount        Decimal
  note          String?
  /// Jika diisi, baris disembunyikan dari riwayat (mis. refund escrow).
  cancelledAt   DateTime?
  createdAt     DateTime @default(now())

  fromUser User @relation("TransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("TransferTo", fields: [toUserId], references: [id], onDelete: Cascade)

  marketplaceEscrowHold MarketplaceEscrowHold?
}

model ShopTransaction {
  id            String   @id @default(cuid())
  transactionId String   @unique
  buyerId       String
  sellerId      String
  amount        Decimal
  fee           Decimal
  description   String?
  createdAt     DateTime @default(now())

  buyer  User @relation("BuyerTx", fields: [buyerId], references: [id], onDelete: Cascade)
  seller User @relation("SellerTx", fields: [sellerId], references: [id], onDelete: Cascade)
}

/// Indikator / file strategi yang dibagikan member (gratis atau berbayar IDR).
model SharedIndicator {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation("SharedIndicatorSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  title       String
  slug        String   @unique
  description String?  @db.Text
  /// 0 = gratis — unduhan langsung tanpa pembelian.
  priceIdr    Decimal  @default(0) @db.Decimal(18, 2)
  /// URL file (mis. Vercel Blob); jangan ekspos di UI tanpa cek izin.
  fileUrl     String
  /// Nama file saat unduh.
  fileName    String
  /// mt4 | mt5 | tradingview | other
  platform    String   @default("mt5") @db.VarChar(16)
  /// Sampul katalog (path publik aman, mis. /indikator-assets/covers/…).
  coverImageUrl String? @db.VarChar(1024)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases IndicatorPurchase[]
  ratings   IndicatorRating[]

  @@index([sellerId])
  @@index([published])
}

/// Rating bintang 1–5 untuk indikator (satu nilai per user per produk).
model IndicatorRating {
  id          String          @id @default(cuid())
  indicatorId String
  indicator   SharedIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stars       Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([indicatorId, userId])
  @@index([indicatorId])
}

/// Hak unduh untuk indikator berbayar (satu baris per pembeli).
model IndicatorPurchase {
  id          String          @id @default(cuid())
  indicatorId String
  indicator   SharedIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User            @relation("IndicatorPurchaseBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  amountIdr   Decimal         @db.Decimal(18, 2)
  createdAt   DateTime        @default(now())
  /// Jika diisi, pembelian dibatalkan (refund escrow) — unduhan ditutup.
  revokedAt   DateTime?

  escrowHold MarketplaceEscrowHold?

  @@unique([indicatorId, buyerId])
  @@index([buyerId])
}

/// Expert Advisor (EA) / robot trading yang dijual member (gratis atau berbayar IDR).
model SharedExpertAdvisor {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation("SharedExpertAdvisorSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  title       String
  slug        String   @unique
  description String?  @db.Text
  priceIdr    Decimal  @default(0) @db.Decimal(18, 2)
  fileUrl     String
  fileName    String
  /// mt4 | mt5 | tradingview | other
  platform    String   @default("mt5") @db.VarChar(16)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases ExpertAdvisorPurchase[]
  ratings   EaRating[]

  @@index([sellerId])
  @@index([published])
}

/// Rating bintang 1–5 untuk EA (satu nilai per user per produk).
model EaRating {
  id        String              @id @default(cuid())
  eaId      String
  ea        SharedExpertAdvisor @relation(fields: [eaId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  stars     Int
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([eaId, userId])
  @@index([eaId])
}

model ExpertAdvisorPurchase {
  id        String              @id @default(cuid())
  eaId      String
  ea        SharedExpertAdvisor @relation(fields: [eaId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User                @relation("ExpertAdvisorPurchaseBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  amountIdr Decimal             @db.Decimal(18, 2)
  createdAt DateTime            @default(now())
  revokedAt DateTime?

  escrowHold MarketplaceEscrowHold?

  @@unique([eaId, buyerId])
  @@index([buyerId])
}

/// Penahanan dana pembelian marketplace (Shopee-style); penjual menerima setelah masa komplain atau konfirmasi.
model MarketplaceEscrowHold {
  id        String @id @default(cuid())
  buyerId   String
  sellerId  String
  amount    Decimal @db.Decimal(18, 2)
  productType MarketplaceEscrowProductType
  status    MarketplaceEscrowStatus @default(PENDING)

  /// Setelah tanggal ini (jika masih PENDING) dana dicairkan ke penjual via cron.
  releaseAt DateTime
  releasedAt DateTime?
  refundedAt DateTime?

  disputeReason String? @db.Text
  adminNote     String? @db.Text

  walletTransferId String @unique
  walletTransfer   WalletTransfer @relation(fields: [walletTransferId], references: [id], onDelete: Cascade)

  indicatorPurchaseId String? @unique
  indicatorPurchase   IndicatorPurchase? @relation(fields: [indicatorPurchaseId], references: [id], onDelete: SetNull)

  eaPurchaseId String? @unique
  eaPurchase   ExpertAdvisorPurchase? @relation(fields: [eaPurchaseId], references: [id], onDelete: SetNull)

  buyer  User @relation("MarketplaceEscrowBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller User @relation("MarketplaceEscrowSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, releaseAt])
  @@index([buyerId, status])
  @@index([sellerId, status])
}

/// Permintaan deposit USDT (BEP-20/BSC) → saldo IDR member.
model UsdtDepositRequest {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Hash transaksi on-chain (unik: satu TX = satu kredit).
  txHash     String            @unique @db.VarChar(66)
  /// Jaringan: "bsc" (BEP-20).
  network    String            @default("bsc") @db.VarChar(16)
  /// Jumlah USDT yang diterima admin (dari log on-chain).
  amountUsdt Decimal           @db.Decimal(18, 6)
  /// Kurs USDT/IDR saat deposit dikonfirmasi.
  rateIdr    Decimal           @db.Decimal(18, 2)
  /// Jumlah IDR yang dikreditkan = amountUsdt × rateIdr.
  amountIdr  Decimal           @db.Decimal(18, 2)
  status     UsdtDepositStatus @default(PENDING)
  /// Diisi jika status = FAILED.
  failReason String?           @db.VarChar(512)
  verifiedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

/// Penawaran pekerjaan pembuatan EA/indikator antar member; dana dikunci saat posting.
model JobOffer {
  id           String         @id @default(cuid())
  title        String         @db.VarChar(200)
  description  String         @db.Text
  category     JobCategory
  /// Budget IDR yang ditawarkan pemberi kerja; dikunci dari wallet saat posting.
  budgetIdr    Decimal        @db.Decimal(18, 2)
  status       JobOfferStatus @default(OPEN)
  /// Batas waktu penerimaan tawaran (default 30 hari dari posting).
  expiresAt    DateTime
  requesterId  String
  requester    User           @relation("JobRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  winnerId     String?
  winner       User?          @relation("JobWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  bids         JobBid[]
  comments     JobComment[]
  deliverables JobDeliverable[]
  /// Timestamp saat pemenang mengumpulkan hasil kerja.
  deliveredAt  DateTime?
  /// Auto-release ke pemenang jika tidak ada komplain setelah waktu ini (deliveredAt + 3 hari).
  autoReleaseAt DateTime?
  completedAt  DateTime?
  disputeReason String?       @db.VarChar(1000)
  adminNote     String?       @db.VarChar(1000)
  /// URL file lampiran PDF (opsional, untuk spesifikasi detail).
  attachmentUrl  String?      @db.VarChar(1000)
  attachmentName String?      @db.VarChar(255)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, expiresAt])
  @@index([status, autoReleaseAt])
  @@index([requesterId])
  @@index([winnerId])
}

/// Tawaran harga dari freelancer untuk sebuah penawaran pekerjaan.
model JobBid {
  id        String       @id @default(cuid())
  jobId     String
  job       JobOffer     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  bidderId  String
  bidder    User         @relation("JobBidder", fields: [bidderId], references: [id], onDelete: Cascade)
  priceIdr  Decimal      @db.Decimal(18, 2)
  message   String       @db.VarChar(1000)
  status    JobBidStatus @default(PENDING)
  createdAt DateTime     @default(now())

  @@unique([jobId, bidderId])
  @@index([jobId])
  @@index([bidderId])
}

/// Komentar privat antara pemberi kerja dan pemenang pada sebuah pekerjaan.
model JobComment {
  id        String   @id @default(cuid())
  jobId     String
  job       JobOffer @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("JobCommenter", fields: [authorId], references: [id], onDelete: Cascade)
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
}

/// File hasil kerja yang dikirim pemenang; trigger masa tunggu 3 hari.
model JobDeliverable {
  id           String   @id @default(cuid())
  jobId        String
  job          JobOffer @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation("JobDeliverer", fields: [uploadedById], references: [id], onDelete: Cascade)
  fileName     String   @db.VarChar(255)
  fileUrl      String   @db.VarChar(1000)
  note         String?  @db.VarChar(500)
  createdAt    DateTime @default(now())

  @@index([jobId])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

/// Item menu header situs publik (href tetap dari kode; admin mengatur label, urutan, aktif).
model SiteHeaderNavItem {
  id        String   @id @default(cuid())
  navKey    String   @unique
  label     String
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

/// Item menu sidebar member (/profil?tab=… atau /profil/portfolio untuk Portofolio). tabKey di-whitelist di aplikasi.
model MemberMenuItem {
  id        String   @id @default(cuid())
  tabKey    String   @unique
  label     String
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

/// Sub-menu portofolio MT (/profil/portfolio/…). tabKey di-whitelist di `portfolioMenu.ts`.
model PortfolioMenuItem {
  id        String   @id @default(cuid())
  tabKey    String   @unique
  label     String
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model ChatConversation {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  updatedAt DateTime @updatedAt

  userA    User          @relation("ConvUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User          @relation("ConvUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@unique([userAId, userBId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  readAt         DateTime?
  createdAt      DateTime         @default(now())
}

model PublicChatMessage {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model InternalMail {
  id         String    @id @default(cuid())
  fromUserId String
  toUserId   String
  subject    String
  body       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  fromUser User @relation("MailFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("MailTo", fields: [toUserId], references: [id], onDelete: Cascade)
}

/// Kunjungan halaman (first-party) untuk ringkasan trafik di admin — bukan pengganti Google Analytics.
model SiteTrafficPageview {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  visitorId    String   @db.VarChar(64)
  path         String   @db.VarChar(2048)
  referrer     String?  @db.VarChar(2048)
  referrerHost String?  @db.VarChar(256)
  utmSource    String?  @db.VarChar(128)
  utmMedium    String?  @db.VarChar(128)
  utmCampaign  String?  @db.VarChar(256)
  /// direct | internal | organic_google | social | other_referral | utm
  entryType    String   @db.VarChar(32)

  @@index([createdAt])
  @@index([visitorId, createdAt])
  @@index([entryType])
  @@index([referrerHost])
}
